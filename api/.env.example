# --- Server ---
PORT=3000
NODE_ENV=development

# --- Frontend origin (CORS allow) ---
FRONTEND_URL=http://localhost:5173

# --- Database (Postgres) ---
DB_NAME=squarepeople
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- Auth ---
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_at_least_16_chars
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string_16chars
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
BCRYPT_SALT_ROUNDS=10

# --- Email (Plan 4 will use these) ---
MAIL_DRIVER=console
RESEND_API_KEY=
RESEND_FROM=SquarePeople <no-reply@squarepeople.cookietechltd.com>
